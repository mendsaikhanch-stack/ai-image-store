# ════════════════════════════════════════════════════════════
# REQUIRED
# ════════════════════════════════════════════════════════════

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_image_store?schema=public"

# Long random string (32+ bytes recommended). In production the app
# will refuse to start if this is missing.
# Generate:  openssl rand -base64 32
#       or:  [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
AUTH_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# ════════════════════════════════════════════════════════════
# APP
# ════════════════════════════════════════════════════════════

# Public base URL used for absolute links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to "true" to show the yellow "DEMO MODE" banner on every page.
# Use for staging demos so reviewers can't confuse demo with production.
NEXT_PUBLIC_DEMO_MODE="false"

# ════════════════════════════════════════════════════════════
# STORAGE
# Local disk paths. On Railway, point STORAGE_SOURCE_DIR at a
# persistent volume (e.g. /app/storage/source) so paid source
# files survive deploys.
# ════════════════════════════════════════════════════════════

STORAGE_SOURCE_DIR="./storage/source"
STORAGE_PREVIEW_DIR="./public/previews"

# ════════════════════════════════════════════════════════════
# PAYMENTS — mock only in staging
# ════════════════════════════════════════════════════════════

PAYMENT_PROVIDER="mock"
# STRIPE_SECRET_KEY=""
# QPAY_MERCHANT_ID=""

# ════════════════════════════════════════════════════════════
# VISION — filename heuristic by default
# ════════════════════════════════════════════════════════════

VISION_PROVIDER="heuristic"
# ANTHROPIC_API_KEY=""

# ════════════════════════════════════════════════════════════
# SEED CREDENTIALS
# Required when running `npm run db:seed` against a production
# database. In dev these default to admin123 / user123 if unset.
# ════════════════════════════════════════════════════════════

SEED_ADMIN_EMAIL="admin@atelier.dev"
SEED_ADMIN_PASSWORD=""
SEED_USER_EMAIL="user@atelier.dev"
SEED_USER_PASSWORD=""
