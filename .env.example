# --- Database ---
# Local PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_image_store?schema=public"

# --- Auth ---
# Use a long random string. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# --- App ---
# Public base URL, used for absolute links and signed download URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Storage (placeholder for MVP) ---
# Local path where source (paid) files live. Never expose this directly.
STORAGE_SOURCE_DIR="./storage/source"
# Public preview directory (served via Next /public)
STORAGE_PREVIEW_DIR="./public/previews"

# --- Payments (MVP uses mock provider) ---
# Provider can be: "mock" | "stripe" | "qpay"
PAYMENT_PROVIDER="mock"
# STRIPE_SECRET_KEY=""
# QPAY_MERCHANT_ID=""

# --- Vision (bulk import metadata suggestions) ---
# Provider can be: "heuristic" | "anthropic"
# "heuristic" (default) parses filenames/folders, no API key required.
# "anthropic" is a stub — see lib/vision/anthropic.ts for enable steps.
VISION_PROVIDER="heuristic"
# ANTHROPIC_API_KEY=""
